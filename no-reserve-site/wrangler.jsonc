{
  "name": "no-reserve-photography",
  "compatibility_date": "2026-06-01",
  "main": "./src/index.js",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "r2_buckets": [
    { "binding": "PHOTOS_BUCKET", "bucket_name": "no-reserve-photos" }
  ],
  "kv_namespaces": [
    { "binding": "GALLERIES", "id": "REPLACE_WITH_YOUR_KV_NAMESPACE_ID" }
  ]
}
